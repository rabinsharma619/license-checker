{
  "name": "license-checker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.mjs",
    "parse": "node --max-old-space-size=8192 scripts/parse-pdfs.mjs",
    "sync": "node --max-old-space-size=8192 server/sync.mjs"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  }
}
